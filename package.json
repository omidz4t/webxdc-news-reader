{
	"name": "webxdc-news-reader",
	"version": "1.2.1",
	"description": "A WebXDC app for reading and browsing news from Telegram channels inside Delta Chat.",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"package": "sed -i 's/version = \".*\"/version = \"'$npm_package_version'\"/' manifest.toml && vite build && cp manifest.toml build/ && cd build && mkdir -p ../dist && rm -f ../dist/news-reader-v$npm_package_version.xdc && zip -r ../dist/news-reader-v$npm_package_version.xdc . && echo \"Created dist/news-reader-v$npm_package_version.xdc\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/omidz4t/webxdc-news-reader.git"
	},
	"author": "Omid Zamani",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/omidz4t/webxdc-news-reader/issues"
	},
	"homepage": "https://github.com/omidz4t/webxdc-news-reader#readme",
	"devDependencies": {
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^11.0.1",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@webxdc/types": "^2.1.2",
		"semantic-release": "^25.0.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"webxdc-types": "^1.0.1"
	},
	"dependencies": {
		"photoswipe": "^5.4.4"
	}
}
